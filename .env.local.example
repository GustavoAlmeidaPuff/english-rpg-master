# ─── Required ────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# ─── Text-to-Speech (ElevenLabs) ─────────────────────────────────────────────
# Free tier: 10,000 characters/month — https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ─── Optional ────────────────────────────────────────────────────────────────
# Default LLM model (used if none is selected in the UI)
# Browse models at https://openrouter.ai/models
DEFAULT_MODEL=mistralai/mistral-nemo

# Embedding model for RAG (must support /embeddings endpoint)
# openai/text-embedding-3-small is cheap and widely supported
EMBEDDING_MODEL=openai/text-embedding-3-small

# App title shown in browser tab and OpenRouter HTTP-Referer header
APP_TITLE=RPG Master

# Public URL (used in OpenRouter headers — optional for local dev)
# NEXT_PUBLIC_APP_URL=https://yourapp.vercel.app
